        <key>HOME</key>
        <string>/Users/wongi</string>
        <key>PYTHONPATH</key>
        <string>/Users/wongi/Desktop/DEV/WG/weekly-report/venv/lib/python3.9/site-packages</string>
    </dict>

    <!-- 부팅/절전 복귀 후 미실행된 경우 실행 -->
