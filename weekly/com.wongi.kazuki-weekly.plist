<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wongi.kazuki-weekly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework/Versions/3.9/bin/python3.9</string>
